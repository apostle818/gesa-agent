ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Docker Compose / Portainer: host port to expose (defaults to 3000)
GESA_AGENT_PORT=3000

# Pin a specific image tag from GHCR (defaults to :latest from main).
# Examples: ghcr.io/apostle818/gesa-agent:v1.0.0
#           ghcr.io/apostle818/gesa-agent:sha-abc1234
# GESA_AGENT_IMAGE=ghcr.io/apostle818/gesa-agent:latest
