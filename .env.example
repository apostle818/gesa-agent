ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Default model versions used when an agent's frontmatter doesn't pin one.
# Anthropic model IDs: https://docs.anthropic.com/en/docs/about-claude/models
# Mistral model IDs:   https://docs.mistral.ai/getting-started/models/
CLAUDE_MODEL=claude-opus-4-7
MISTRAL_MODEL=mistral-large-latest

# How many times to retry a Mistral request on HTTP 429 before surfacing
# the error. Respects the Retry-After header, capped at 15s per wait.
MISTRAL_MAX_RETRIES=4

# Docker Compose / Portainer: host port to expose (defaults to 3000)
GESA_AGENT_PORT=3000

# Pin a specific image tag from GHCR (defaults to :latest from main).
# Examples: ghcr.io/apostle818/gesa-agent:v1.0.0
#           ghcr.io/apostle818/gesa-agent:sha-abc1234
# GESA_AGENT_IMAGE=ghcr.io/apostle818/gesa-agent:latest

# -----------------------------------------------------------------------------
# Git-backed agent persistence (optional)
#
# When GESA_AGENTS_REPO_URL is set, every agent created/edited/deleted in the
# GUI is committed and pushed to this private repo. On boot, the app pulls
# the remote so edits survive container restarts without a local volume.
#
# Works with any HTTPS git host (GitHub, Gitea, Forgejo, GitLab, Bitbucket).
# Authentication is via a Personal Access Token with read+write on this one
# repo (no extra scopes needed).
# -----------------------------------------------------------------------------
# GESA_AGENTS_REPO_URL=https://gitea.example.com/you/gesa-agents.git
# GESA_AGENTS_TOKEN=your-fine-grained-PAT-here
# GESA_AGENTS_BRANCH=main
# GESA_AGENTS_COMMIT_NAME=gesa-agent
# GESA_AGENTS_COMMIT_EMAIL=gesa-agent@localhost
